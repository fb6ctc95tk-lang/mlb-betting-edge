# =============================================================
# MLB Betting Edge — Environment Variables Template
# =============================================================
#
# HOW TO USE THIS FILE:
#   1. Copy this file and rename the copy to: backend/.env
#   2. Replace every placeholder value with your real values
#   3. Never share backend/.env with anyone
#   4. This .env.example file is safe to share — it has no real values
#
# =============================================================


# -------------------------------------------------------------
# SportsDataIO API Key (PAUSED — not currently used)
# Where to get it: https://sportsdata.io → My Account → API Keys
# What it looks like: a long string of letters and numbers
# -------------------------------------------------------------
SPORTSDATAIO_API_KEY=your_api_key_here


# -------------------------------------------------------------
# OddsAPI.io API Key (ACTIVE — used for moneyline odds)
# Where to get it: https://odds-api.io → Dashboard → API Keys
# What it looks like: a long string of letters and numbers
# Free tier: 100 requests/hour, 2 sportsbooks, no credit card needed
# See docs/ODDS_API_SETUP.md for full instructions
# -------------------------------------------------------------
ODDS_API_KEY=your_api_key_here


# -------------------------------------------------------------
# Database URL
# Format: postgresql://username:password@host:port/database_name
#
# Local development (your own machine):
#   - username: your PostgreSQL username (often "postgres")
#   - password: the password you set when installing PostgreSQL
#   - host: localhost (means "this computer")
#   - port: 5432 (PostgreSQL default, don't change unless you know why)
#   - database_name: mlb_betting_edge
#
# Example: postgresql://postgres:mypassword@localhost:5432/mlb_betting_edge
# -------------------------------------------------------------
DATABASE_URL=postgresql://your_username:your_password@localhost:5432/mlb_betting_edge
